{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qianyi.local/schemas/ai-resume-optimizer-report.schema.json",
  "title": "AI Resume Optimizer Report",
  "type": "object",
  "required": [
    "summaryScore",
    "starLevel",
    "position",
    "overallComment",
    "dimensions",
    "impressions",
    "suggestions",
    "rewriteSamples",
    "riskWarnings",
    "status"
  ],
  "properties": {
    "summaryScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "starLevel": { "type": "integer", "minimum": 1, "maximum": 5 },
    "position": { "type": "string", "minLength": 1 },
    "overallComment": { "type": "string", "minLength": 1 },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimensionScore" }
    },
    "impressions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/impression" }
    },
    "suggestions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/suggestion" }
    },
    "rewriteSamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/rewriteSample" }
    },
    "riskWarnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/riskWarning" }
    },
    "status": { "enum": ["OK", "ERROR"] },
    "errorMessage": { "type": ["string", "null"] }
  },
  "additionalProperties": false,
  "$defs": {
    "dimensionScore": {
      "type": "object",
      "required": ["key", "label", "score", "comment"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "comment": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "impression": {
      "type": "object",
      "required": ["label", "description"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "suggestion": {
      "type": "object",
      "required": ["type", "title", "reason", "improvedText", "actionHint"],
      "properties": {
        "type": { "enum": ["TRIM", "EXPAND", "SUPPLEMENT", "REWRITE", "AI_FUSION"] },
        "title": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "originalText": { "type": ["string", "null"] },
        "improvedText": { "type": "string", "minLength": 1 },
        "actionHint": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "rewriteSample": {
      "type": "object",
      "required": ["beforeText", "afterText", "note"],
      "properties": {
        "beforeText": { "type": "string", "minLength": 1 },
        "afterText": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "riskWarning": {
      "type": "object",
      "required": ["category", "severity", "message", "action"],
      "properties": {
        "category": { "enum": ["AUTHENTICITY", "GAP", "MISSING_DATA", "POSITION_MISMATCH"] },
        "severity": { "enum": ["LOW", "MEDIUM", "HIGH"] },
        "message": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}

